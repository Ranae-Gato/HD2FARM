                  <ID>184</ID>
                  <Description>"SC SUPPLY POD - 4 SLOTS"</Description>
                  <Options moHideChildren="1"/>
                  <Color>FF8000</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>[ENABLE]
{$lua}
function HellpodDataReplacer0()
  gHellpodDataPointer = AOBScan("79 75 4F 01 CA 13 49 A9 B2 50 46 93", "-W")
  if gHellpodDataPointer == nil then
    print("Error: Could not find HellpodData pattern.")
    return
  end
  
  local baseAddr = gHellpodDataPointer[1]
  local count = gHellpodDataPointer.getCount()
  print("Found " .. count .. " occurrence(s) of the container pattern")
  
  local itemPattern = AOBScan("79 75 4F 01 CA 13 49 A9", "-W")
  if itemPattern == nil then
    print("Error: Could not find item pattern.")
    gHellpodDataPointer.destroy()
    return
  end
  
  local itemCount = itemPattern.getCount()
  print("Found " .. itemCount .. " occurrence(s) of the item pattern")
  
  local baseNum = tonumber(baseAddr)
  if baseNum == nil then
    baseNum = getAddress(baseAddr)
  end
  
  local slots = {}
  local maxDistance = 4096
  
  local i = 0
  while not (i &gt;= itemCount) do
    local success, addr = pcall(function() return itemPattern[i] end)
    if success and addr ~= nil then
      local addrNum = tonumber(addr)
      if addrNum == nil then
        addrNum = getAddress(addr)
      end
      if addrNum ~= nil then
        local distance = math.abs(addrNum - baseNum)
        if not (distance &gt;= maxDistance) then
          table.insert(slots, {addr = addrNum, distance = distance})
        end
      end
    else
      break
    end
    i = i + 1
  end
  
  table.sort(slots, function(a, b)
    local distA = a.distance
    local distB = b.distance
    if not (distA &gt;= distB) then
      return true
    end
    return false
  end)
  
  local slotCount = #slots
  print("Found " .. slotCount .. " items within range of base address")
  
  if slotCount &gt;= 1 then
    registerSymbol("HellpodDataAddr1", slots[1].addr)
    print("Slot 1 registered at distance " .. slots[1].distance)
  end
  if slotCount &gt;= 2 then
    registerSymbol("HellpodDataAddr2", slots[2].addr)
    print("Slot 2 registered at distance " .. slots[2].distance)
  end
  if slotCount &gt;= 3 then
    registerSymbol("HellpodDataAddr3", slots[3].addr)
    print("Slot 3 registered at distance " .. slots[3].distance)
  end
  if slotCount &gt;= 4 then
    registerSymbol("HellpodDataAddr4", slots[4].addr)
    print("Slot 4 registered at distance " .. slots[4].distance)
  else
    print("Warning: Only found " .. slotCount .. " slots, expected 4")
  end
  
  gHellpodDataPointer.destroy()
  itemPattern.destroy()
end
HellpodDataReplacer0()
