            <CheatEntry>
              <ID>154505</ID>
              <Description>"Hellpod Rack"</Description>
              <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
              <Color>0000FF</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>//Author : Zodiac
//CE     : 7.6
//Game   : HELLDIVERS™ 2
//Version: 01.003.200
//Process: helldivers2.exe
//Module : game.dll
//Inject : game.dll+108B314
//Date   : 15/07/25
//Comment: Script made for Experimental Division.

{$lua}
if syntaxcheck then return end

local hellpodrackcallcheck = getAddressSafe('HellpodRackCall')

if hellpodrackcallcheck == nil then
  showMessage("Some of required addresses were not found!\nActivate the Stratagems script first!")
  error()
  return
end

{$asm}

[ENABLE]

aobscanmodule(racks,game.dll,0F 10 10 0F 10 40 30) //Unique
aobscanmodule(hellpod_rack_select,game.dll,48 8B 08 E8 ? ? ? ? 48 8B F8 48 85 C0 75 ? 48) //Unique
alloc(newmem,64,racks)
alloc(newmem2,32,hellpod_rack_select)
label(rackValue return scriptcode2 return2)
registersymbol(racks hellpod_rack_select rackValue)

newmem:
  push rbx
  pushfq
  test rcx,rcx
  jnz short @f
  mov rbx,rackValue
  mov [rbx],rax

@@:
  popfq
  pop rbx
  movups xmm2,[rax]
  movups xmm0,[rax+30]
  jmp return
  align 10

rackValue:
  dq 0
  align 10 CC

racks:
  jmp newmem
  nop 2
return:

//------------------------------------------------------------------------------

newmem2:
  push rbx
  mov rbx,rackValue
  mov [rbx],rax
  pop rbx

scriptcode2:
  mov rcx,[rax]
  call HellpodRackCall
  jmp return2
  align 10 CC

hellpod_rack_select:
  jmp newmem2
  nop 3
return2:

[DISABLE]

racks:
  db 0F 10 10 0F 10 40 30

hellpod_rack_select:
  db 48 8B 08
  call HellpodRackCall

unregistersymbol(*)
dealloc(*)

