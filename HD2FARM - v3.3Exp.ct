//aobscanmodule(LegitNR2,game.dll,8B 07 85 C0 74 ? 83) //Unique
alloc(baseLNoReloadMem,480,baseLNoReload)
alloc(shotgunLeGnewmem,192,shotgunLeG)
alloc(shotgunP2newmem,32,shotgunLeP2)
//alloc(newmemLegitNR2,48,LegitNR2)
//alloc(senatormem,48,senatorLnR)
label(rifleLnR commandoLnR machinegunLnR uziLnR assaultrifleLnR assaultrifleVer2 variable codeLnR returnLnR bushLnR shotgunLeGCode returnshotgunLeG returnshotgunLeP2) //returnLegitNR2 returnSenat
registersymbol(baseLNoReload shotgunLeG shotgunLeP2) //LegitNR2 senatorLnR

baseLNoReloadMem:
  push rax
  pushfq
  test rsi,rsi
  jz codeLnR
  mov eax,FFFFFFFF
  cmp edi,eax
  je codeLnR
  mov eax,[r12+88]
  cmp eax,4 //commando
  je commandoLnR
  cmp eax,3 //epoch
  je commandoLnR
  cmp eax,#175 //machine gun
  je machinegunLnR
  cmp eax,#250 //stalwart
  je machinegunLnR
  cmp eax,#100 //HMG
  je machinegunLnR
  cmp eax,#31 //UZI
  je uziLnR
  cmp eax,#7 //sniper rifle &amp; wasp launcher
  je commandoLnR
  cmp eax,#10 //grenade launcher
  je commandoLnR
  cmp eax,#56 //assault rifle
  je assaultrifleLnR
  cmp eax,#14 //mech rocket launcher
  je commandoLnR
  cmp eax,#13 //warrant pistol
  je commandoLnR
  cmp eax,#30 //anti-tank emplacement
  je commandoLnR
  cmp eax,#300 //anti-iditos emplacement
  je machinegunLnR
  cmp eax,#15 //counter sniper &amp; dominator
  je assaultrifleVer2
  cmp eax,9 //accelerator
  je commandoLnR
  cmp eax,5 //crossbow &amp; eruptor
  je commandoLnR
  cmp eax,#16 //breaker
  je assaultrifleVer2
  cmp eax,#20 //amendment
  je assaultrifleVer2
  cmp eax,#49 //variable
  je variable
  cmp eax,#12 //HALO pistol
  je commandoLnR

rifleLnR:
  cmp r14d,1
  jbe codeLnR
  cmp r14d,8
  ja codeLnR
  mov r14d,#10
  jmp codeLnR

machinegunLnR:
  mov eax,[r12+9C]
  cmp eax,1
  je short @f //anti-iditos emplacement separation from mech autocannon
  mov eax,[r12+9C]
  test eax,eax
  jz commandoLnR //mech autocannon separation

@@:
  cmp r14d,1
  jbe codeLnR
  cmp r14d,#30
  ja codeLnR
  mov r14d,#35
  jmp codeLnR

commandoLnR:
  mov eax,[r12+8C]
  cmp eax,5
  je assaultrifleVer2 //assault rifle dissect
  mov eax,1
  cmp r14d,eax
  cmovb r14d,eax
  jmp codeLnR

uziLnR:
  cmp r14d,1
  jbe codeLnR
  cmp r14d,7
  ja codeLnR
  mov r14d,9
  jmp codeLnR

assaultrifleLnR:
  cmp r14d,1
  jbe codeLnR
  cmp r14d,8
  ja codeLnR
  mov r14d,(int)10
  jmp codeLnR

assaultrifleVer2:
  cmp r14d,1
  jbe codeLnR
  cmp r14d,4
  ja codeLnR
  mov r14d,6
  jmp codeLnR

variable:
  cmp r14d,1
  jbe codeLnR
  cmp r14d,7
  ja codeLnR
  mov r14d,(int)11
  jmp codeLnR

codeLnR:
  popfq
  pop rax
  mov [rcx+rax+04],r14d
  jmp returnLnR
  align 10 CC

baseLNoReload:
  jmp baseLNoReloadMem
returnLnR:

