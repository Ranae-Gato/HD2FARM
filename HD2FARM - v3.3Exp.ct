//Comment: Script made for Experimental Division.

[ENABLE]

aobscanmodule(OrbitLaserEditor,game.dll,8B 87 ? ? ? ? F3 0F 11 ? ? ? 89) //Unique
alloc(scriptmem,64,OrbitLaserEditor)
label(scriptcode LaserEditorV scriptreturn)
registersymbol(OrbitLaserEditor LaserEditorV scriptcode)

scriptmem:
  push rax
  push rbx
  mov rax,LaserEditorV
  lea rbx,[rdi+1C8]
  mov [rax],rbx
  pop rbx
  pop rax

scriptcode:
  reassemble(OrbitLaserEditor)
  jmp scriptreturn
  align 10

LaserEditorV:
  dq 0
  align 10 CC

OrbitLaserEditor:
  jmp scriptmem
  nop
scriptreturn:

[DISABLE]

OrbitLaserEditor:
  reassemble(scriptcode)

unregistersymbol(*)
dealloc(*)

