aobscanmodule(baseLNoReload,game.dll,44 89 74 01 ? 4D 8B 42 ? 49 8B 42 ? 49 83 C0 ? 4C 03 C1 48 8B ? D0 BA ? ? ? ? 8B 49 ? 48 83 C4 ? 41 5E E9 ? ? ? ? 3B C2 75 ? 41 8B 43 ? ? ? CC CC CC CC CC CC CC CC CC CC CC CC CC CC CC CC 48) //Unique
aobscanmodule(shotgunLeG,game.dll,45 89 74 10 ? 41 BA ? ? ? ? 4D 8B 41 ? 49 83 C0 ? ? ? 3B C2) //Unique
aobscanmodule(shotgunLeP2,game.dll,45 89 74 10 ? 41 BA ? ? ? ? 4D 8B 41 58 49 83 C0 ? 49 8B 41 ? 4C) //Unique
