label(return_Syringes)

newmem_Syringes:
  mov edx,[r14+rbp*8+04] // Load current syringes
  mov ecx,eax
  cmp edx, #1            // Check if we only have 1 left
  jbe @f                 // If 1 or less, skip the decrement
    dec edx              // Otherwise, subtract 1
  @@:
  mov [r14+rbp*8+04],edx // Save the new value
  jmp return_Syringes

aob_Syringes:
  jmp newmem_Syringes
  nop 2                  // NOP the original 'dec edx' (FF CA)
return_Syringes:

