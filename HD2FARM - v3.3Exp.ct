              <AssemblerScript>//Author : Jane
//CE     : 7.6
//Game   : HELLDIVERS™ 2
//Version: 01.002.203
//Process: helldivers2.exe
//Module : game.dll
//Inject : game.dll+783CAC
//Date   : 26/04/25
//Comment: Script made for Experimental Division.

[ENABLE]

aobscanmodule(staminaLegit,game.dll,F3 41 0F 11 08 48 8B 84) //Unique
alloc(scriptmem,64,staminaLegit)
label(staminaSetUp scriptreturn)
registersymbol(staminaLegit staminaSetUp)

scriptmem:
  push rax
  pushfq
  mov rax,staminaSetUp
  mov [rax],r8
  comiss xmm1,[rax+8]
  jae short @f
  movss xmm1,[rax+C]

@@:
  popfq
  pop rax
  movss [r8],xmm1
  jmp scriptreturn
  align 10

staminaSetUp:
  dq 0
  dq 3E8000003E19999A  //  dd (float)0.15  //  dd (float)0.25
  align 10 CC

staminaLegit:
  jmp scriptmem
scriptreturn:

