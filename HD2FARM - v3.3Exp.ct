aobscanmodule(damageMulti,game.dll,66 0F 6E 59 04 66 0F 6E 49 08 0F 5B C9 0F 5B DB) // should be unique
registersymbol(damageMulti)
alloc(dmg_newmem,$2000)

label(dmg_code)
label(dmg_return)

dmg_newmem:
  cmp [rcx+04],#0 // skip any 0 dmg weapons like smoke or unknown shit
  je dmg_code

// whitelisted weapons that get super damage
  cmp [rcx+00], #12 // Projectile_Flamethrower FLAM-40 part 1
    je dmg_Super
  cmp [rcx+00], #27 // Projectile_Grenade_40mm_HE GL-21 part 1 projectile / mortar shell (turret)
    je dmg_Super
  cmp [rcx+00], #37 // Projectile_Laser_Long LAS-16 Sickle
    je dmg_Super
  cmp [rcx+00], #43 // Projectile_Plasma_Bolt SG-8P Punisher Plasma (1) / PLAS-1 Scorcher
    je dmg_Super
  cmp [rcx+00], #44 // Projectile_Plasma_Punisher
    je dmg_Super
  cmp [rcx+00], #50 // Projectile_Plasma_Rifle_Charge
    je dmg_Super
  cmp [rcx+00], #51 // Projectile_Railgun RS-422 railgun
    je dmg_Super
  cmp [rcx+00], #57 // Projectile_Pistol_9x20mm_fmj P-19 Redeemer
    je dmg_Super
  cmp [rcx+00], #55 // Projectile_Pistol_9x20mm_smj MP-98 Knight
    je dmg_Super
  cmp [rcx+00], #59 // Projectile_Pistol_9x20mm_hp P-2 Peacemaker
    je dmg_Super
  cmp [rcx+00], #67 // Projectile_Pistol_12x25mm_fmj SMG-37 Defender
    je dmg_Super
  cmp [rcx+00], #73 // Projectile_Pistol_12x25mm_stun SMG-72 Pummeler
    je dmg_Super
  cmp [rcx+00], #74 // SMG-72 Pummeler
    je dmg_Super
  cmp [rcx+00], #75 // Projectile_Pistol_Magnum P-113 Verdict
    je dmg_Super
  cmp [rcx+00], #76 // Halo Pistol
    je dmg_Super
  cmp [rcx+00], #77 // P-92 Warrant
    je dmg_Super
  cmp [rcx+00], #78 // SMG-32 Reprimand
    je dmg_Super
  cmp [rcx+00], #80 // Projectile_Pistol_13x40mm_fmj P-4 Senator
    je dmg_Super
  cmp [rcx+00], #85 // Projectile_Rifle_5p5x50mm_ap AR-23P Liberator Penetrator
    je dmg_Super
  cmp [rcx+00], #87 // Projectile_Rifle_5p5x50mm_exp AR-23C Liberator Concussive
    je dmg_Super
  cmp [rcx+00], #88 // Projectile_Rifle_5p5x50mm_fmj AR-23 Liberator / AR-22C Patriot / AR-48 Truth Whisperer / M-105 Stalwart / AR-61 Tenderizer / Guard Dog
    je dmg_Super
