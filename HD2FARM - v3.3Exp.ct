            <CheatEntry>
              <ID>172599</ID>
              <Description>"Mission Stratagem Swap"</Description>
              <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
              <Color>40FF00</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>//Author : Zodiac, Kael
//CE     : 7.6
//Game   : HELLDIVERS™ 2
//Version: 01.003.104
//Process: helldivers2.exe
//Module : game.dll
//Inject : game.dll+1084D1F
//Date   : 29/06/25
//Comment: Script made for Experimental Division.

{$lua}
if syntaxcheck then return end

local AOBs = {
    checkforaddr1 = 'MissionStratsSwap',
    checkforaddr2 = 'calloriginstruction'
}

for AOBname, AOB in pairs(AOBs) do
    _G[AOBname] = getAddressSafe(AOB)
    if _G[AOBname] == nil then
        showMessage("Some of required addresses were not found!\nActivate the Stratagems script first!")
        error()
        return
    end
end

{$asm}

[ENABLE]

alloc(scriptmem,80,MissionStratsSwap)
label(missionStratEnd MissionStratsSwap_code missionstrat_label scriptreturn)
registersymbol(MissionStratsSwap_code missionstrat_label)

scriptmem:
  push rax
  push rbx
  push rcx
  pushfq
  mov eax,[rbx+8]
  cmp eax,119EF38F //fake mech remove
  je short missionStratEnd
  mov rax,missionstrat_label
  lea rbx,[rbx+08]
  mov ecx,[rbx]
  mov ecx,[rdi+10]
  cmp ecx,(float)65.25 //slot 1 check
  je short @f
  lea rax,[rax+8]

@@:
  mov [rax],rbx

missionStratEnd:
  popfq
  pop rcx
  pop rbx
  pop rax

MissionStratsSwap_code:
  mov ecx,[rbx+08]
  call calloriginstruction
  jmp scriptreturn
  align 10

missionstrat_label:
  dq 0
  dq 0
  align 10 CC

MissionStratsSwap:
  jmp scriptmem
  nop 3
scriptreturn:

[DISABLE]

MissionStratsSwap:
  db 8B 4B 08
  call calloriginstruction

unregistersymbol(*)
dealloc(*)

//Original Instructions:
//game.dll+1084CFF - BA 01000000             - mov edx,00000001
//game.dll+1084D04 - 4D 8B C5                - mov r8,r13
//game.dll+1084D07 - 49 8B 08                - mov rcx,[r8]
//game.dll+1084D0A - 39 41 04                - cmp [rcx+04],eax
//game.dll+1084D0D - 74 59                   - je game.dll+1084D68
//game.dll+1084D0F - FF C2                   - inc edx
//game.dll+1084D11 - 49 83 C0 08             - add r8,08
//game.dll+1084D15 - 83 FA 73                - cmp edx,73
//game.dll+1084D18 - 72 ED                   - jb game.dll+1084D07
//game.dll+1084D1A - E9 AD010000             - jmp game.dll+1084ECC
//------------------------------------------------------------------------------
//game.dll+1084D1F - 8B 4B 08                - mov ecx,[rbx+08]
//------------------------------------------------------------------------------
//game.dll+1084D22 - E8 294CD1FF             - call game.dll+D99950
//game.dll+1084D27 - 48 85 C0                - test rax,rax
//game.dll+1084D2A - 74 13                   - je game.dll+1084D3F
//game.dll+1084D2C - 48 8B 48 08             - mov rcx,[rax+08]
//game.dll+1084D30 - E8 1BF845FF             - call game.dll+4E4550
//game.dll+1084D35 - 48 85 C0                - test rax,rax
//game.dll+1084D38 - 74 05                   - je game.dll+1084D3F
//game.dll+1084D3A - 44 8B 00                - mov r8d,[rax]
//game.dll+1084D3D - EB 37                   - jmp game.dll+1084D76
//game.dll+1084D3F - 8B 43 08                - mov eax,[rbx+08]
</AssemblerScript>
