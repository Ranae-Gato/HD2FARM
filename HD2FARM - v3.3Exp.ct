aobscanmodule(aob_SubtractAmmo, game.dll, 42 83 2C ?? 01 48 8B 45 ??)
registersymbol(aob_SubtractAmmo)
alloc(newmem_SubtractAmmo, 1024, game.dll)
label(return_SubtractAmmo)

newmem_SubtractAmmo:
  // Dynamically check the pointer based on what the AOB found
  // Usually [rcx+r8*4] or [r11+rax*4]
  cmp [rcx+r8*4], #2  // This assumes RCX/R8 are still used; if not, you must check registers
  jle short @f
    sub [rcx+r8*4], #1
  @@:
  // We restore the MOV instruction found at the end of the AOB
  mov rax,[rbp+38]
  jmp return_SubtractAmmo

aob_SubtractAmmo:
  jmp newmem_SubtractAmmo
  nop 4 // NOP out the remaining bytes of the original 9-byte sequence
return_SubtractAmmo:

[DISABLE]
