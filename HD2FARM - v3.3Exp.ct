            <CheatEntry>
              <ID>154465</ID>
              <Description>"Stratagems"</Description>
              <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
              <Color>0000FF</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>//Author : Rei
//CE     : 7.6
//Game   : HELLDIVERS™ 2
//Version: 01.002.201
//Process: helldivers2.exe
//Module : ~
//Inject : ~
//Date   : 31/03/25
//Comment: Script made for Experimental Division.

[ENABLE]
{$STRICT}
//48 8D ? ? ? ? ? 0F 1F 40 00 4C 8B 02 41 39 48 04 ? ? FF C0 48 83 C2 08 83 F8 ? ? ? 33 C0
alloc(DataStrats,288,game.dll)
label(endstratload StratStructure loadStrat)
registersymbol(DataStrats StratStructure loadStrat)

DataStrats:
  push rax
  push rbx
  push rcx
  push rdx
  push rsi
  push rdi
  pushfq
  mov rax,StratStructure
  xor rbx,rbx
  mov [rax+C],rbx
  mov [rax+14],rbx
  mov [rax+1C],rbx
  mov [rax+24],rbx
  mov [rax+2C],rbx
  mov [rax+34],rbx
  mov [rax+3C],rbx
  mov [rax+44],rbx
  mov [rax+4C],rbx
  mov ebx,[rax+8] // strat ID
  mov ecx,1
  cmp ebx,ecx
  cmovl ebx,ecx
  mov ecx,maxStratID
  cmp ebx,ecx
  cmova ebx,ecx
  mov [rax+8],ebx
  dec ebx
  mov rcx,stratAddr
  lea rbx,[rbx*8+rcx] //strat ID * 8 + strat address
  mov [rax],rbx
  mov edx,4
  mov rbx,[rbx+8] //buttons load route
  mov rbx,[rbx+30]
  mov ecx,[rbx]
  cmp ecx,edx
  ja short endstratload
  test ecx,ecx
  jz short endstratload
  mov esi,9 //buttons amount
  xor edi,edi

@@:
  mov [rax+rdi*8+C],rbx
  add rbx,rdx
  mov ecx,[rbx]
  cmp ecx,edx
  ja short @f
  test ecx,ecx
  jz short @f
  inc edi
  dec esi
  jnz short @b

endstratload:
  popfq
  pop rdi
  pop rsi
  pop rdx
  pop rcx
  pop rbx
  pop rax
  ret
  align 10

StratStructure:
  dq 0
  dd 1 //strat ID
  dq 0 //button 1
  dq 0 //button 2
  dq 0 //button 3
  dq 0 //button 4
  dq 0 //button 5
  dq 0 //button 6
  dq 0 //button 7
  dq 0 //button 8
  dq 0 //button 9
  align 10 CC

loadStrat:

{$lua}
if syntaxcheck then return end

if maxStratID == 1 then
  showMessage("Error getting max stratagem ID!")
  error()
  return
else
  funcTokenStrat = true
end

local function loopStrat()
autoAssemble([[
createthread(loadStrat)
loadStrat:
  call short DataStrats
  ret
  align 10 CC
]])
end

local function loopLoadStrat()
  while funcTokenStrat do
  loopStrat()
  sleep(100)
  end
end

createThread(loopLoadStrat)

{$asm}
[DISABLE]

{$lua}
funcTokenStrat = false

{$asm}
unregistersymbol(*)
dealloc(*)
</AssemblerScript>
              <CheatEntries>
                <CheatEntry>
                  <ID>170499</ID>
                  <Description>"Apply Config (Edit in Script)"</Description>
                  <Color>00FFFF</Color>
                  <VariableType>Auto Assembler Script</VariableType>
                  <AssemblerScript>{$lua}
if syntaxcheck then return end

stratValues = {
  {
   id = 28,
   Button1 = 3,
   Button2 = 3,
   Button3 = 3,
   Button4 = 3,
   SpawnTime = 0,
   Cooldown = 0,
 },
 {
   id = 85,
   Button1 = 2,
   Button2 = 2,
   Button3 = 2,
   Button4 = 2,
   Button5 = 2,
   Button6 = 2,
   Button7 = 2,
   Button8 = 2,
   Button9 = 2,
   Category = 5,
   Uses = 5,
   SpawnTime = 5,
   SpawnRadius = 5,
   BeaconLingerTime = 5,
   ExtraTravelTime = 5,
   Cooldown = 5,
   CooldownIfFail = 5,
   OriginType = 5,
   CallInType = 5,
   CallInFlags = 127,
   ObjectiveRequirement = 5,
   StratFlags = 3,
   TriggersWar = 0,
   CooldownType = 5,
   Payload1 = 9333151595628803334,
   Payload2 = 13650214626151558605,
   PayloadPosition = 5,
   Package = 9039463537364420120,
   Icon = 14707318144884798948,
   HudType = 5,
   Cost = 5,
   Enabled = 1,
   DependsOn = 5,
   AdditionalStratID = 5,
   MaxInLoadout = 5,
   BeaconColor = 5,
   ShipLaserPointer = 5,
   UseAlternateCooldown = 1,
   ExtraHellpods = 2
 },

 -- insert more values here

}

local function compareID(IDStratagems, sameStratIDs)
  if IDStratagems.id &lt;= 0 then
    showMessage("Stratagem ID (" .. IDStratagems.id .. ") cannot be null or negative.")
    error()
    return
  elseif IDStratagems.id &gt; maxStratID then
    showMessage("Stratagem ID (" .. IDStratagems.id .. ") exceeds max Stratagem ID (" .. maxStratID .. ").")
    error()
    return
  elseif sameStratIDs[IDStratagems.id] then
    showMessage("Duplicate Stratagem ID found: " .. IDStratagems.id)
    error()
    return
  end
  sameStratIDs[IDStratagems.id] = true
end

local sameStratIDs = {}
  for _, IDStratagems in ipairs(stratValues) do
  compareID(IDStratagems, sameStratIDs)
end

[ENABLE]

local game      = getAddressSafe('game.dll')
local stratscan = getAddressSafe('stratAddrFindScan')

if game == nil or stratscan == nil then
  showMessage("Addresses not found! Please restart the game.")
  error()
  return
end

applyStrat_mem = allocateMemory(448, game)
registerSymbol('applyStratagem', applyStrat_mem, true)

for _, values in ipairs(stratValues) do
local StratASM = [[
  createthread(applyStratagem)
  applyStratagem:
  push rax
  push rbx
  push rcx
  mov ecx,#%d
  call stratAddrFindScan
]]

local StratASM = StratASM:format(values.id)

local offsets = {
  Button1 = 0x00,
  Button2 = 0x04,
  Button3 = 0x08,
  Button4 = 0x0C,
  Button5 = 0x10,
  Button6 = 0x14,
  Button7 = 0x18,
  Button8 = 0x1C,
  Button9 = 0x20,
  Category = 0x2C,
  Uses = 0x40,
  SpawnTime = 0x44,
  SpawnRadius = 0x48,
  BeaconLingerTime = 0x50,
  ExtraTravelTime = 0x54,
  Cooldown = 0x58,
  CooldownIfFail = 0x5C,
  OriginType = 0x60,
  CallInType = 0x64,
  CallInFlags = 0x68,
  ObjectiveRequirement = 0x6C,
  StratFlags = 0x70,
  TriggersWar = 0x80,
  CooldownType = 0x84,
  Payload1 = 0x00,
  Payload2 = 0x08,
  PayloadPosition = 0x90,
  Package = 0x98,
  Icon = 0xA0,
  HudType = 0xA8,
  Cost = 0xAC,
  Enabled = 0xB0,
  DependsOn = 0xB4,
  AdditionalStratID = 0xB8,
  MaxInLoadout = 0xBC,
  BeaconColor = 0xC0,
  ShipLaserPointer = 0xC4,
  UseAlternateCooldown = 0x120,
  ExtraHellpods = 0x124
}

for type, offset in pairs(offsets) do
  if values[type] ~= nil then
    if type == "SpawnTime" or type == "SpawnRadius" or type == "BeaconLingerTime" or
       type == "ExtraTravelTime"or type == "Cooldown" or type == "CooldownIfFail" then
         StratASM = StratASM .. string.format("mov ebx,(float)%f\n", values[type])
         StratASM = StratASM .. string.format("mov [rax+%X],ebx\n", offset)
    elseif type == "Package" or type == "Icon" then
         StratASM = StratASM .. string.format("mov rbx,%d\n", values[type])
         StratASM = StratASM .. string.format("mov [rax+%X],rbx\n", offset)
    elseif type:match("^Button%d$") then
         StratASM = StratASM .. string.format("mov rbx,[rax+30]\n")
         StratASM = StratASM .. string.format("mov [rbx+%X],#%d\n", offset, values[type])
    elseif type:match("^Payload%d$") then
         StratASM = StratASM .. string.format("mov rbx,[rax+88]\n")
         StratASM = StratASM .. string.format("mov rcx,%d\n", values[type])
         StratASM = StratASM .. string.format("mov [rbx+%X],rcx\n", offset)
    else
         StratASM = StratASM .. string.format("mov ebx,#%d\n", values[type])
         StratASM = StratASM .. string.format("mov [rax+%X],ebx\n", offset)
    end
  end
end

local StratASM = StratASM .. [[
  pop rcx
  pop rbx
  pop rax
  ret
  align 10 CC
]]

autoAssemble(StratASM)

end

[DISABLE]

unregisterSymbol('applyStratagem')
deAlloc(applyStrat_mem)

</AssemblerScript>
