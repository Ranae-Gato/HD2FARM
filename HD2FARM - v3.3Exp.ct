//Date   : 13/03/25
//Comment: Script made for Experimental Division.

[ENABLE]

aobscanmodule(hellpodsettings,game.dll,F2 0F 11 44 24 ? 44 ? ? ? ? ? ? 74) //Unique
alloc(newmem,80,hellpodsettings)
label(code podHeight return)
registersymbol(hellpodsettings podHeight)

newmem:
  push rax
  push rbx
  pushfq
  mov rax,podHeight
  mov rbx,73F8498BFFDCF415 //on mission hellpod hash
  cmp rdx,rbx
  jne short @f //E58163E71928D3E2 - diving in hellpod hash
  lea rbx,[rcx-108]
  jmp short code

@@:
  lea rbx,[rcx-B0]

code:
  mov [rax],rbx
  popfq
  pop rbx
  pop rax
  movsd [rsp+20],xmm0
  jmp return
  align 10

podHeight:
  dq 0
  align 10 CC

hellpodsettings:
  jmp newmem
  nop
return:

[DISABLE]

hellpodsettings:
  db F2 0F 11 44 24 20

unregistersymbol(*)
dealloc(*)

