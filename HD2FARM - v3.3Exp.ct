          <Color>00FFFF</Color>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript>//Author : Zodiac, HavocBlitz
//CE     : 7.6
//Game   : HELLDIVERS™ 2
//Version: 01.003.201
//Process: helldivers2.exe
//Module : game.dll
//Inject : ~
//Date   : 28/07/25
//Comment: Script made for Experimental Division.

{$C}

#include &lt;stdint.h&gt;

extern uint64_t GodMode_mem;
extern uint64_t GodMode_mem2;

{$asm}
[ENABLE]

{$lua}
if syntaxcheck then return end

godmode_token = false

math.randomseed(os.time())

local min = 1000000
local max = 1100000

function generateRandNum()
  randNum = math.random(min, max)
end

function godmode()
autoAssemble([[
createthread(call_godmode)
call_godmode:
  call short hp_ccode
  ret
  align 10 CC
]])
end

game = getAddress('game.dll')

local pattern = ('4C 8B 05 ? ? ? ? 41 8B 50 ? 45 8B 50 ? 44 0F AF D3') --Unique

local scan = AOBScanModuleUnique('game.dll', pattern)

GodMode_mem  = allocateMemory(16, game)
GodMode_mem2 = GodMode_mem + 4

local write_scan = writeQword(GodMode_mem2, scan)

local writeint3 = {}
for i = 1, 4 do
    writeint3[i] = 0xCC
end

local writeCCbytes = writeBytes(GodMode_mem2 + 8, writeint3) -- aligment by 16

local regSymbols = {
    "GodMode_mem",
    "GodMode_mem2"
}

for _, regSymbol in ipairs(regSymbols) do
    registerSymbol(regSymbol, _G[regSymbol], true)
end

{$asm}
aobscanmodule(removeIntegerLimit_scan,$process,7F ? 41 3B C6 8B F8 41 0F 4C FE 89 3E) //Unique, // helldivers2.exe+3210D3
aobscanmodule(removeHealthLimit,game.dll,0F 4F E8 83 FF ? 74 ? F3) //Unique
alloc(hp_ccode,32,game.dll)
label(call_godmode)
registersymbol(removeIntegerLimit_scan removeIntegerLimit removeHealthLimit hp_ccode call_godmode)
define(removeIntegerLimit,removeIntegerLimit_scan+B)

removeIntegerLimit:
  nop 2

//------------------------------------------------------------------------------

removeHealthLimit+2:
  db +5 //cmovg ebp,ebp

//------------------------------------------------------------------------------

hp_ccode:
{$ccode PREFIX=GodMode_ NODEBUG }

uint32_t randNum = GodMode_mem;
uintptr_t InstAddr = GodMode_mem2;

uint32_t ptr_offset = *(uint32_t*)(InstAddr + 3);
uintptr_t baseHealthPtr = InstAddr + ptr_offset + 7;

if (baseHealthPtr != 0)
{
    uintptr_t ptr1 = *(uintptr_t*)baseHealthPtr;
    if (ptr1 != 0)
    {
        uintptr_t healthPtr1 = ptr1 + 0x20;
        uintptr_t ptr2 = *(uintptr_t*)healthPtr1;

        if (ptr2 != 0)
        {
            uintptr_t healthPtr2 = ptr2 + 0x400;
            uintptr_t healthPtr3 = ptr2 + 0x410;
            uintptr_t healthPtr4 = ptr2 + 0x420;
            uintptr_t healthPtr5 = ptr2 + 0x430;

            int val;

            val = *(uint32_t*)healthPtr2;
            if ((val &gt;= 11 &amp;&amp; val &lt; 126) || (val &gt;= (randNum - 28000) &amp;&amp; val &lt;= (randNum + 28000)))
                *(uint32_t*)healthPtr2 = randNum;

            val = *(uint32_t*)healthPtr3;
            if ((val &gt;= 11 &amp;&amp; val &lt; 126) || (val &gt;= (randNum - 28000) &amp;&amp; val &lt;= (randNum + 28000)))
                *(uint32_t*)healthPtr3 = randNum;

            val = *(uint32_t*)healthPtr4;
            if ((val &gt;= 11 &amp;&amp; val &lt; 126) || (val &gt;= (randNum - 28000) &amp;&amp; val &lt;= (randNum + 28000)))
                *(uint32_t*)healthPtr4 = randNum;

            val = *(uint32_t*)healthPtr5;
            if ((val &gt;= 11 &amp;&amp; val &lt; 126) || (val &gt;= (randNum - 28000) &amp;&amp; val &lt;= (randNum + 28000)))
                *(uint32_t*)healthPtr5 = randNum;
        }
    }
}

{$asm}
  ret
  align 10 CC

call_godmode:

{$lua}
if syntaxcheck then return end

godmode_token = true

local function godmodeLoop()
  while godmode_token do
  generateRandNum()
  writeInteger(GodMode_mem, randNum)
  godmode()
  sleep(1000)
  end
end

createThread(godmodeLoop)

{$asm}
[DISABLE]

{$lua}
godmode_token = false

local delete_symbols = {
  'GodMode_mem',
  'GodMode_mem2'
}

for _, delete_symbol in ipairs(delete_symbols) do
  unregisterSymbol(delete_symbol)
end

deAlloc(GodMode_mem)

{$asm}

removeIntegerLimit:
  db 89 3E

removeHealthLimit+2:
  db -5

unregistersymbol(*)
dealloc(*)

