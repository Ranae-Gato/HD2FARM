aobscanmodule(HpRegen,game.dll,48 03 C9 8B 14 ? E9) //Unique
aobscanmodule(removeIntegerLimit_scan,$process,7F ? 41 3B C6 8B F8 41 0F 4C FE 89 3E) //Unique, // helldivers2.exe+3210D3
aobscanmodule(removeHealthLimit,game.dll,0F 4F E8 83 FF ? 74 ? F3) //Unique
alloc(HpRegenMem,144,HpRegen)
label(HpRegenLabel HpRegenReturn)
registersymbol(removeIntegerLimit_scan removeIntegerLimit removeHealthLimit HpRegen HpRegenLabel)
define(removeIntegerLimit,removeIntegerLimit_scan+B)

removeIntegerLimit:
  nop 2

//------------------------------------------------------------------------------

removeHealthLimit+2:
  db +5 //cmovg ebp,ebp

//------------------------------------------------------------------------------

HpRegenMem:
  add rcx,rcx
  push rax
  push rbx
  push rcx
  push rdx
  push rsi
  pushfq
  lea rax,[rax+rcx*8]
  mov rbx,HpRegenLabel
  mov [rbx],rax
  mov ecx,[rbx+C]
  mov edx,1
  cmp ecx,edx
  cmovl ecx,edx
  mov [rbx+C],ecx
  mov ecx,[rax]
  test ecx,ecx
  jle short @f
  mov edx,[rbx+14]
  cmp ecx,edx
  jae short @f
  mov edx,[rbx+8]
  cmp ecx,edx
  jae short @f
  mov edx,[rbx+C]
  mov esi,[rbx+10]
  inc esi
  mov [rbx+10],esi
  cmp esi,edx
  jb short @f
  inc ecx
  xor esi,esi
  mov [rbx+10],esi
  mov [rax],ecx

@@:
  popfq
  pop rsi
  pop rdx
  pop rcx
  pop rbx
  pop rax
  mov edx,[rax+rcx*8]
  jmp HpRegenReturn
  align 10

HpRegenLabel:
  dq 0 //currentPlayerHP pointer [rdx]
  dq 0000004B0000007D //regenThreshold [rdx+8] &amp; regen rate [rdx+C] (int)75 &amp; (int)125
  dq 0000007D00000000 //loop counter [rdx+10] &amp; Max health to regenerate (int)125 &amp; 0
  align 10 CC

HpRegen:
  jmp HpRegenMem
  nop
HpRegenReturn:

[DISABLE]

removeIntegerLimit:
  db 89 3E

removeHealthLimit+2:
  db -5

HpRegen:
  db 48 03 C9 8B 14 C8

