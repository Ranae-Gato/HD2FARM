              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>{ Game   : helldivers2.exe
  Version: 
  Date   : 2026-02-03
  Author : cfemen

  Speedhack

  Fixed by Igromanru
}

[ENABLE]
aobscanmodule(aobPlayerSpeed,game.dll,F3 0F 59 4B ? F3 0F 59 4B)
alloc(newmem,$100)

label(code)
label(return)
label(bFreeze)
label(fSpeed)
label(aobPlayerSpeedBackUp)
registersymbol(bFreeze)
registersymbol(fSpeed)
registersymbol(aobPlayerSpeed aobPlayerSpeedBackUp)

newmem:
 cmp [rbx+10],1
 je Player
 cmp [rbx+10],5
 je Player
 jmp Enemy
Player:
 mov rax,fSpeed
 mulss xmm1,[rax]
aobPlayerSpeedBackUp:
 readMem(aobPlayerSpeed, 17)
 jmp return
Enemy:
 cmp byte ptr[bFreeze],1
 jne code
 xorps xmm1,xmm1
code:
  readMem(aobPlayerSpeed, 17)
  jmp return
bFreeze:
db 0
fSpeed:
dd (float)3.0

aobPlayerSpeed:
  jmp far newmem
  nop 3
return:

[DISABLE]
aobPlayerSpeed:
  readMem(aobPlayerSpeedBackUp, 17)

