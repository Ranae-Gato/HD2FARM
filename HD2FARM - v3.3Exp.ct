alloc(legitNoOHMemL,80,legitNoOHLasers)
label(legitNoOHCode legitNoOHRet legitNoOHLRet)
registersymbol(legitNoOHSickle legitNoOHLasers)

legitNoOHMem:
  push rax
  pushfq
  sub rsp,10
  movaps [rsp],xmm1
  mov eax,(float)50.0
  movd xmm1,eax
  comiss xmm1,[r14]
  je short @f
  mov eax,(float)70.0
  movd xmm1,eax
  comiss xmm0,xmm1
  jbe short legitNoOHCode
  movaps xmm1,[rsp]
  add rsp,10
  popfq
  pop rax
  jmp legitNoOHRet

@@:
  mov eax,(float)50.0 //50.0 for double sickle to prevent taking the damage from overheat
  movd xmm1,eax
  comiss xmm0,xmm1
  jbe short @f
  movaps xmm1,[rsp]
  add rsp,10
  popfq
  pop rax
  jmp legitNoOHRet

legitNoOHCode:
