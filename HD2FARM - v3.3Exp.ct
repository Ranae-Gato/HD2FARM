          <CheatEntries>
            <CheatEntry>
              <ID>154429</ID>
              <Description>"Stratagem Selection Swap"</Description>
              <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
              <Color>40FF00</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>//Author : Zodiac
//CE     : 7.6
//Game   : HELLDIVERS™ 2
//Version: 01.003.101
//Process: helldivers2.exe
//Module : game.dll
//Inject : game.dll+F27777
//Date   : 10/06/25
//Comment: Script made for Experimental Division.

[ENABLE]

aobscanmodule(SSSwap,game.dll,44 8B CE 45 85 D2 74 ? 49) //Unique
alloc(newmem,64,SSSwap)
label(stratEdit_Val return)
registersymbol(SSSwap stratEdit_Val)

newmem:
  push rax
  pushfq
  cmp r10,4
  jne short @f
  mov rax,stratEdit_Val
  mov [rax],r11

@@:
  popfq
  pop rax
  mov r9d,esi
  test r10d,r10d
  jmp return
  align 10

stratEdit_Val:
  dq 0
  align 10 CC

SSSwap:
  jmp newmem
  nop
return:

[DISABLE]

SSSwap:
  db 44 8B CE 45 85 D2

unregistersymbol(*)
dealloc(*)

