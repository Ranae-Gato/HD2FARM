            <CheatEntry>
              <ID>170895</ID>
              <Description>"Current Stratagems"</Description>
              <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
              <Color>40FF00</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>//Author : Zodiac
//CE     : 7.6
//Game   : HELLDIVERS™ 2
//Version: 01.003.000
//Process: helldivers2.exe
//Module : game.dll
//Inject : game.dll+591B1B
//Date   : 14/05/25
//Comment: Script made for Experimental Division.

[ENABLE]
{$STRICT}
aobscanmodule(CStrat,game.dll,8B B9 ? ? ? ? 83 FF ? 75) //Unique
alloc(stratagemSlot,480,CStrat)
label(slot2 slot3 slot4 slot5 slot6 slot7 slot8 slot9 slot10 slot11 slot12 slot13 slot14 CStratCode origstratcode stratagemSlot_val CSReturn)
registersymbol(CStrat origstratcode stratagemSlot_val)

stratagemSlot:
  push rax
  push rbx
  push rcx
  pushfq
  db 48 8D 81
  readmem(CStrat+2,4) //lea rax,[rcx+00000158]
  mov rbx,stratagemSlot_val
  xor rcx,rcx
  cmp r8,rcx
  jne short @f
  jmp CStratCode

slot2:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+8]
  jmp CStratCode

slot3:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+10]
  jmp CStratCode

slot4:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+18]
  jmp CStratCode

slot5:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+20]
  jmp CStratCode

slot6:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+28]
  jmp CStratCode

slot7:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+30]
  jmp CStratCode

slot8:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+38]
  jmp CStratCode

slot9:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+40]
  jmp CStratCode

slot10:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+48]
  jmp CStratCode

slot11:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+50]
  jmp CStratCode

slot12:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+58]
  jmp CStratCode

slot13:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+60]
  jmp CStratCode

slot14:
  inc rcx
  cmp r8,rcx
  jne short @f
  lea rbx,[rbx+68]

CStratCode:
  mov [rbx],rax
  cmp r8,D
  jne short @f
  lea rax,[rax+28]
  mov ecx,[rax]
  test ecx,ecx
  jz short @f
  lea rbx,[rbx+8]
  mov [rbx],rax //slot 15
  lea rax,[rax+28]
  mov ecx,[rax]
  test ecx,ecx
  jz short @f
  lea rbx,[rbx+8]
  mov [rbx],rax //slot 16
  lea rax,[rax+28]
  mov ecx,[rax]
  test ecx,ecx
  jz short @f
  lea rbx,[rbx+8]
  mov [rbx],rax //slot 17

@@:
  popfq
  pop rcx
  pop rbx
  pop rax

origstratcode:
  reassemble(CStrat)
  jmp CSReturn
  align 10

stratagemSlot_val:
  dq 0 //(1)
  dq 0 //(2)
  dq 0 //(3)
  dq 0 //(4)
  dq 0 //(5)
  dq 0 //(6)
  dq 0 //(7)
  dq 0 //(8)
  dq 0 //(9)
  dq 0 //(10)
  dq 0 //(11)
  dq 0 //(12)
  dq 0 //(13)
  dq 0 //(14)
  dq 0 //(15)
  dq 0 //(16)
  dq 0 //(17 - reserve)
  align 10 CC

CStrat:
  jmp stratagemSlot
  nop
CSReturn:

[DISABLE]

CStrat:
  reassemble(origstratcode)

unregistersymbol(*)
dealloc(*)

//Original Instructions:
