            <CheatEntry>
              <ID>172572</ID>
              <Description>"Get Mission Stratagem ID"</Description>
              <Options moHideChildren="1" moDeactivateChildrenAsWell="1"/>
              <Color>40FF00</Color>
              <VariableType>Auto Assembler Script</VariableType>
              <AssemblerScript>//Author : Zodiac
//CE     : 7.6
//Game   : HELLDIVERS™ 2
//Version: 01.003.102
//Process: helldivers2.exe
//Module : game.dll
//Inject : game.dll+1206F5C
//Date   : 14/06/25
//Comment: Script made for Experimental Division.

[ENABLE]

aobscanmodule(getmissionstratslots,game.dll,48 8B DA 48 8B D1 83 F8) //Unique
aobscanmodule(loadmissionstratID,game.dll,44 8B C2 4C 8B CE) //Unique
alloc(scriptmem,80,getmissionstratslots)
alloc(scriptmem2,128,loadmissionstratID)
label(scriptcode missionstratslots scriptreturn MSS6 MSS7 MSS8 MSS9 MSS10 MSS11 MSS12 loadMSID scriptcode2 scriptreturn2)
registersymbol(getmissionstratslots missionstratslots loadmissionstratID)

scriptmem:
  push rbx
  mov rbx,missionstratslots
  mov [rbx],eax
  pop rbx

scriptcode:
  mov rbx,rdx
  mov rdx,rcx
  jmp scriptreturn
  align 10

missionstratslots:
  dq 0 //slot 1 (5)
  dq 0 //slot 2 (6) &amp; slot 3 (7)
  dq 0 //slot 4 (8) &amp; slot 5 (9)
  dq 0 //slot 6 (10) &amp; slot 7 (11)
  dd 0 //slot 8 (12) reserve
  align 10 CC
  
getmissionstratslots:
  jmp scriptmem
  nop
scriptreturn:

//------------------------------------------------------------------------------

scriptmem2:
  push rax
  push rbx
  pushfq
  mov rax,missionstratslots
  mov ebx,[rax]
  cmp ebx,5 //slot 1 (5)
  jz short loadMSID
  cmp ebx,6 //slot 2 (6)
  je short MSS6
  cmp ebx,7 //slot 3 (7)
  je short MSS7
  cmp ebx,8 //slot 4 (8)
  je short MSS8
  cmp ebx,9 //slot 5 (9)
  je short MSS9
  cmp ebx,#10 //slot 6 (10)
  je short MSS10
  cmp ebx,#11 //slot 7 (11)
  je short MSS11
  cmp ebx,#11 //slot 8 (12) reserve
  je short MSS12
  jmp short scriptcode2

MSS6:
  lea rax,[rax+4]
  jmp short loadMSID

MSS7:
  lea rax,[rax+8]
  jmp short loadMSID

MSS8:
  lea rax,[rax+C]
  jmp short loadMSID

MSS9:
  lea rax,[rax+10]
  jmp short loadMSID

MSS10:
  lea rax,[rax+14]
  jmp short loadMSID

MSS11:
  lea rax,[rax+18]
  jmp short loadMSID

MSS12:
  lea rax,[rax+1C] //reserve

loadMSID:
  mov [rax+4],edx

scriptcode2:
  popfq
  pop rbx
  pop rax
  mov r8d,edx
  mov r9,rsi
  jmp scriptreturn2
  align 10 CC

loadmissionstratID:
  jmp scriptmem2
  nop
scriptreturn2:


[DISABLE]

getmissionstratslots:
  db 48 8B DA 48 8B D1

loadmissionstratID:
  db 44 8B C2 4C 8B CE

unregistersymbol(*)
dealloc(*)

//Original Instructions:
//game.dll+1206F48 - CC                      - int 3 
//game.dll+1206F49 - CC                      - int 3 
//game.dll+1206F4A - CC                      - int 3 
