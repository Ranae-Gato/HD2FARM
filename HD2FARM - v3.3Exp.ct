aobscanmodule(payloadingame,game.dll,48 8B 1B 4C 8B CB E8) //Unique
alloc(newmem,48,payload_new)
alloc(newmem2,32,payloadingame)
label(code payload_val return code2 return2)
registersymbol(payload_new payload_val payloadingame)

newmem:
  push rax
  mov rax,payload_val
  mov [rax],rbx
  pop rax

code:
  mov r11,[rbx]
  mov rcx,r11
  jmp return
  align 10

payload_val:
  dq 0
  align 10 CC

payload_new:
  jmp newmem
  nop
return:

//------------------------------------------------------------------------------

newmem2:
  push rax
  mov rax,payload_val
  mov [rax],rbx
  pop rax

code2:
  mov rbx,[rbx]
  mov r9,rbx
  jmp return2
  align 10 CC

payloadingame:
  jmp newmem2
  nop
return2:

[DISABLE]

payload_new:
  db 4C 8B 1B 49 8B CB

payloadingame:
  db 48 8B 1B 4C 8B CB

unregistersymbol(*)
dealloc(*)

