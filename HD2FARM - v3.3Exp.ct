        <CheatEntry>
          <ID>52</ID>
          <Description>"Set Run Speed"</Description>
          <Options moManualExpandCollapse="1"/>
          <VariableType>Auto Assembler Script</VariableType>
          <AssemblerScript Async="1">{ Game   : helldivers2.exe
  Version:
  Date   : 2025-05-19
  Author : cfemen

  This script does blah blah blah
}

[ENABLE]
aobscanmodule(aobPlayerSpeed,game.dll,F3 0F 59 4B 78 F3 0F 59 4B 7C 0F 28 D9 F3 0F 5C DC) // should be unique
alloc(newmem,$1000)
alloc(fSpeed, 4)

fSpeed:
dd (float)2

label(code)
label(return)
label(bFreeze)
registersymbol(bFreeze)
registersymbol(fSpeed)
newmem:
 // RSI = (Index * 0xF4) + 0x70 = Entry ( RBX )
 cmp [rbx+10],1
 je Player
 cmp [rbx+10],5
 je Player
 jmp Enemy
Player:
 mov rax,fSpeed
 mulss xmm1,[rax]
 mulss xmm1,[rbx+78]
 mulss xmm1,[rbx+7C]
 movaps xmm3,xmm1
 subss xmm3,xmm4
 jmp return
Enemy:
 cmp byte ptr[bFreeze],1
 jne code
  xorps xmm1,xmm1
code:
  mulss xmm1,[rbx+78]
  mulss xmm1,[rbx+7C]
  movaps xmm3,xmm1
  subss xmm3,xmm4
  jmp return
bFreeze:
db 0

aobPlayerSpeed:
  jmp far newmem
  nop 3
return:
registersymbol(aobPlayerSpeed)

[DISABLE]

aobPlayerSpeed:
  db F3 0F 59 4B 78 F3 0F 59 4B 7C 0F 28 D9 F3 0F 5C DC

unregistersymbol(*)
dealloc(*)


</AssemblerScript>
