//game.dll+1206F52 - 48 83 EC 20             - sub rsp,20
//game.dll+1206F56 - 8B 81 6CDB0000          - mov eax,[rcx+0000DB6C]
//------------------------------------------------------------------------------
//game.dll+1206F5C - 48 8B DA                - mov rbx,rdx
//game.dll+1206F5F - 48 8B D1                - mov rdx,rcx
//------------------------------------------------------------------------------
